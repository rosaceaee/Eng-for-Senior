{
  "expo": {
    "name": "영어 기초 공부",
    "slug": "Eng-for-Senior",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/thumb.png",
    "scheme": "engforsenior",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/thumb.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.corydalis.EngforSenior"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/thumb.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/thumb.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#1165C0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "754e90a1-aba8-421b-aaa6-056ed16081fc"
      }
    },

    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/754e90a1-aba8-421b-aaa6-056ed16081fc"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
